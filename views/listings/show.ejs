<% layout('layouts/boilerplate.ejs') %>

<div class="row mt-3">
  <div class="col-8 offset-2 mb-3">
    <div class="d-flex justify-content-between align-items-center">
      <h3><%= listing.title %></h3>
      <% if (currentUser && listing.owner._id.toString() !==
      currentUser._id.toString()) { %>
      <a href="/bookings/new/<%= listing._id %>" class="btn btn-primary">
        <i class="fas fa-calendar-check"></i> Book Now
      </a>
      <% } %>
    </div>
  </div>

  <div class="card col-6 offset-3 show-card listing">
    <img
      src="<%= listing.image %>"
      class="card-img-top show-img"
      alt="listing_image"
    />
    <div class="card-body">
      <div class="mb-2">
        <span class="badge bg-primary mb-2"><%= listing.category %></span>
        <div>
          Owned by <i><p>Posted by: <%= listing.owner.username %></p></i>
        </div>
      </div>
      <div><strong>Description:</strong> <%= listing.description %></div>
      <div class="mb-2">
        <strong>Price:</strong> ₹<%= listing.price.toLocaleString("en-IN") %>
        /night
      </div>
      <div class="mb-2">
        <strong>Location:</strong> <%= listing.location %>, <%= listing.country
        %>
      </div>
      <div class="row mb-2">
        <div class="col-md-4">
          <i class="fas fa-bed"></i>
          <strong><%= listing.bedrooms %></strong> bedroom<%= listing.bedrooms
          !== 1 ? 's' : '' %>
        </div>
        <div class="col-md-4">
          <i class="fas fa-bath"></i>
          <strong><%= listing.bathrooms %></strong> bathroom<%=
          listing.bathrooms !== 1 ? 's' : '' %>
        </div>
        <div class="col-md-4">
          <i class="fas fa-users"></i>
          <strong><%= listing.capacity %></strong> guest<%= listing.capacity !==
          1 ? 's' : '' %>
        </div>
      </div>
      <% if(listing.amenities && listing.amenities.length > 0) { %>
      <div class="mb-2">
        <strong>Amenities:</strong>
        <div class="mt-1">
          <% for(let amenity of listing.amenities) { %>
          <span class="badge bg-light text-dark me-1"><%= amenity %></span>
          <% } %>
        </div>
      </div>
      <% } %> <% if(listing.averageRating > 0) { %>
      <div class="mb-2">
        <strong>Rating:</strong>
        <span class="text-warning">
          <i class="fas fa-star"></i> <%= listing.averageRating.toFixed(1) %>
        </span>
        <small class="text-muted">(<%= listing.totalReviews %> reviews)</small>
      </div>
      <% } %> <% if (currentUser && listing.owner.equals(currentUser._id)) { %>
      <div class="alert alert-info">
        <i class="fas fa-info-circle"></i>
        <strong>Property Owner:</strong> This is your property. <% if
        (!hasBankAccount) { %> <br /><strong class="text-warning"
          >⚠️ You need to add a bank account to receive payments!</strong
        >
        <br /><a href="/bank-accounts/new" class="btn btn-warning btn-sm mt-2">
          <i class="fas fa-university"></i> Add Bank Account
        </a>
        <% } else { %>
        <br />You have a bank account set up and will receive payouts
        automatically. <% } %>
      </div>
      <% } %>
    </div>
  </div>

  <% if (currentUser && listing.owner._id.toString() ===
  currentUser._id.toString()) { %>
  <div class="row justify-content-center mt-4 mb-5 text-center">
    <div class="col-md-2 col-10 mb-2 mb-md-0">
      <a href="/listings/<%= listing._id %>/edit">
        <button class="btn edit-btn w-100">Edit</button>
      </a>
    </div>
    <div class="col-md-2 col-10">
      <form
        action="/listings/<%= listing._id %>/delete?_method=DELETE"
        method="post"
      >
        <button class="btn btn-dark w-100">Delete</button>
      </form>
    </div>
  </div>
  <% } %> <% if (currentUser) { %>
  <div class="col-12 col-md-8 col-lg-6 mx-auto review-section mb-3">
    <h4>Leave a Review</h4>
    <form
      action="/listings/<%= listing._id %>/reviews"
      method="post"
      novalidate
      class="review-form needs-validation"
    >
      <!-- Only fieldset rating retained -->
      <fieldset class="starability-slot mb-3">
        <legend>Rating:</legend>
        <input
          type="radio"
          id="no-rate"
          class="input-no-rate"
          name="review[rating]"
          value="0"
          checked
          aria-label="No rating."
        />
        <input
          type="radio"
          id="first-rate1"
          name="review[rating]"
          value="1"
          required
        />
        <label for="first-rate1" title="Terrible">1 star</label>
        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
        <label for="first-rate2" title="Not good">2 stars</label>
        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
        <label for="first-rate3" title="Average">3 stars</label>
        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
        <label for="first-rate4" title="Very good">4 stars</label>
        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
        <label for="first-rate5" title="Amazing">5 stars</label>
      </fieldset>

      <div>
        <label for="comment" class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          cols="30"
          rows="5"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please add some comment for review</div>
      </div>
      <button type="submit" class="btn btn-primary mt-3">Submit</button>
    </form>
  </div>

  <h4 class="mt-4">All Reviews</h4>

  <% if (listing.reviews.length > 0) { %>
  <div class="row">
    <% for (let review of listing.reviews) { %>
    <div class="col-12 col-md-6 col-lg-4 mb-4">
      <div
        class="d-flex flex-column justify-content-between p-3 border rounded shadow-sm bg-light h-100 review-card"
      >
        <div>
          <h5>@<%= review.author.username %></h5>
          <hr />
          <p class="mb-2">
            <strong>Rating:</strong>
          </p>
          <p class="starability-result" data-rating="<%= review.rating %>">
            Rated: <%= review.rating %> star<%= review.rating > 1 ? 's' : '' %>
          </p>

          <p class="mb-0"><%= review.comment %></p>
        </div>
        <form
          action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
          method="post"
          class="mt-3"
        >
          <button class="btn btn-sm btn-dark w-40">Delete</button>
        </form>
      </div>
    </div>
    <% } %>
  </div>
  <% } else { %>
  <p>No reviews yet. Be the first to leave one!</p>
  <% } %> <% } %>
</div>
