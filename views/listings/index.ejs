<body>
  <div class="row mb-4">
    <div class="col-md-8">
      <h3>All Listings</h3>
    </div>
    <div class="col-md-4 text-end">
      <a href="/listings/new" class="btn btn-primary">
        <i class="fas fa-plus"></i> Add New Listing
      </a>
    </div>
  </div>

  <!-- Search and Filter Form -->
  <div class="card mb-4">
    <div class="card-body">
      <form method="GET" action="/listings" class="row g-3">
        <div class="col-md-4">
          <input
            type="text"
            class="form-control"
            name="search"
            placeholder="Search listings..."
            value="<%= locals.search || '' %>"
          />
        </div>
        <div class="col-md-2">
          <input
            type="number"
            class="form-control"
            name="minPrice"
            placeholder="Min Price"
            value="<%= locals.minPrice || '' %>"
          />
        </div>
        <div class="col-md-2">
          <input
            type="number"
            class="form-control"
            name="maxPrice"
            placeholder="Max Price"
            value="<%= locals.maxPrice || '' %>"
          />
        </div>
        <div class="col-md-2">
          <input
            type="text"
            class="form-control"
            name="location"
            placeholder="Location"
            value="<%= locals.location || '' %>"
          />
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-outline-primary w-100">
            <i class="fas fa-search"></i> Search
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Results Count -->
  <div class="mb-3">
    <small class="text-muted">
      Found <%= data.length %> listing<%= data.length !== 1 ? 's' : '' %>
    </small>
  </div>

  <div class="row gx-4 gy-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
    <% for(let listing of data){ %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card h-100">
          <img
            src="<%= listing.image%>"
            class="card-img-top"
            alt="listing_image"
            style="height: 20rem"
          />
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h6 class="card-title mb-0"><%= listing.title %></h6>
              <span class="badge bg-primary"><%= listing.category %></span>
            </div>
            <p class="card-text text-muted mb-2">
              <i class="fas fa-map-marker-alt"></i> <%= listing.location %>, <%=
              listing.country %>
            </p>
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <strong class="text-primary"
                  >₹<%= listing.price.toLocaleString("en-IN")%></strong
                >
                /night
              </div>
              <div class="text-warning">
                <% if(listing.averageRating > 0) { %>
                <i class="fas fa-star"></i> <%= listing.averageRating.toFixed(1)
                %>
                <small class="text-muted">(<%= listing.totalReviews %>)</small>
                <% } else { %>
                <small class="text-muted">No reviews yet</small>
                <% } %>
              </div>
            </div>
            <div class="mt-2">
              <small class="text-muted">
                <i class="fas fa-bed"></i> <%= listing.bedrooms %> bed •
                <i class="fas fa-bath"></i> <%= listing.bathrooms %> bath •
                <i class="fas fa-users"></i> Up to <%= listing.capacity %>
                guests
              </small>
            </div>
          </div>
        </div>
      </a>
    </div>
    <% } %>
  </div>

  <% if(data.length === 0) { %>
  <div class="text-center py-5">
    <i class="fas fa-search fa-3x text-muted mb-3"></i>
    <h5 class="text-muted">No listings found</h5>
    <p class="text-muted">Try adjusting your search criteria</p>
  </div>
  <% } %>
</body>
